# Publer API credentials
# Copy this file to .env and fill in your values.
# Get these from: Publer → Settings → API → Generate API Key
#                 Publer → Settings → Connected Accounts (for account IDs)

PUBLER_API_KEY=your-api-key-here
PUBLER_WORKSPACE_ID=your-workspace-id-here
PUBLER_LINKEDIN_ACCOUNT_ID=your-linkedin-account-id-here
PUBLER_TWITTER_ACCOUNT_ID=your-twitter-account-id-here
PUBLER_INSTAGRAM_ACCOUNT_ID=your-instagram-account-id-here
